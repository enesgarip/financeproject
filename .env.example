VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
# Optional: Sentry error monitoring (frontend project DSN). Leave empty to disable.
VITE_SENTRY_DSN=
# Optional: Web Push VAPID public key (roadmap Y1). Leave empty to disable the
# notifications feature. Generate a keypair with `npx web-push generate-vapid-keys`;
# put the PUBLIC key here, and set the PRIVATE key as a Supabase secret
# (VAPID_PRIVATE_KEY) for the push-notify edge function.
VITE_VAPID_PUBLIC_KEY=

# Supabase Edge Function secrets (set with `supabase secrets set`, do not expose
# these to Vite/browser builds).
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
